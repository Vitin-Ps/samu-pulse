# ============================================================
# SAMU Pulse — Template de Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA coloque valores reais neste arquivo!
# ============================================================

# --- URL do frontend (usada nos links do e-mail) ---
SITE_URL=http://localhost:3000

# --- Banco de Dados ---
DB_URL=jdbc:postgresql://localhost:5432/medinsight
DB_USERNAME=
DB_PASSWORD=

# --- JWT ---
# Mínimo 32 caracteres para HS256
JWT_SECRET=
# Expiração em milissegundos (86400000 = 24h)
JWT_EXPIRATION_MS=86400000

# --- Servidor ---
SERVER_PORT=8080

# --- Debug (true em local/dev, false ou ausente em produção) ---
DEBUG_ERRORS=false

# --- Integrações futuras ---
# SOME_API_KEY=
# SOME_API_SECRET=
